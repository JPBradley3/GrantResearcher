doc_id <- "1DrXIoSMsCDUWayUq29VQXNfLColOqU1Q3Ojr7hfK-PQ"
url <- paste0(
"https://docs.google.com/document/d/",
doc_id,
"/export?format=txt"
)
# -------------------------
# Download Text
# -------------------------
response <- GET(url)
text_data <- content(response, "text")
# Preview raw text
cat(substr(text_data, 1, 2000))
# -------------------------
# Split Into Entries
# -------------------------
entries <- unlist(
strsplit(text_data, "\n\\s*\n")
)
# Remove empty entries
entries <- entries[entries != ""]
# -------------------------
# Build Data Frame
# -------------------------
grant_df <- tibble(raw = entries) %>%
mutate(
organization = str_extract(raw, "^[^\n]+"),
description = str_trim(
str_replace(raw, "^[^\n]+\n?", "")
)
)
# -------------------------
# Add Classification Tags
# -------------------------
grant_df <- grant_df %>%
mutate(
mental_health = str_detect(
str_to_lower(description),
"mental health|behavioral health"
),
housing = str_detect(
str_to_lower(description),
"housing|homeless"
),
autism = str_detect(
str_to_lower(description),
"autism"
),
workforce = str_detect(
str_to_lower(description),
"workforce|employment|job"
)
)
# -------------------------
# Create Simple Match Score
# -------------------------
grant_df <- grant_df %>%
mutate(
score =
mental_health * 3 +
housing * 2 +
autism * 2 +
workforce * 1
) %>%
arrange(desc(score))
# -------------------------
# Print Results
# -------------------------
print(grant_df)
# -------------------------
# Save CSV
# -------------------------
write.csv(
grant_df,
"grant_database.csv",
row.names = FALSE
)
cat("\nSaved: grant_database.csv\n")
# =========================
# Better Google Doc Parser
# =========================
library(httr)
library(dplyr)
library(stringr)
library(tibble)
# -------------------------
# Google Doc Export URL
# -------------------------
doc_id <- "1DrXIoSMsCDUWayUq29VQXNfLColOqU1Q3Ojr7hfK-PQ"
url <- paste0(
"https://docs.google.com/document/d/",
doc_id,
"/export?format=txt"
)
# -------------------------
# Download Text
# -------------------------
response <- GET(url)
text_data <- content(response, "text", encoding = "UTF-8")
# -------------------------
# Normalize Formatting
# -------------------------
# Replace multiple blank lines with special separator
clean_text <- text_data %>%
str_replace_all("\r", "") %>%
str_replace_all("\n{3,}", "|||ENTRY|||")
# -------------------------
# Split More Reliably
# -------------------------
entries <- unlist(
str_split(clean_text, "\\|\\|\\|ENTRY\\|\\|\\|")
)
# Remove empty entries
entries <- entries[
str_trim(entries) != ""
]
# -------------------------
# Build Data Frame
# -------------------------
grant_df <- tibble(
raw = str_trim(entries)
) %>%
mutate(
# First line as organization
organization = str_extract(raw, "^[^\n]+"),
# Everything after first line
description = str_trim(
str_replace(raw, "^[^\n]+\n?", "")
)
)
# -------------------------
# Add NLP Tags
# -------------------------
grant_df <- grant_df %>%
mutate(
mental_health = str_detect(
str_to_lower(description),
"mental health|behavioral health"
),
housing = str_detect(
str_to_lower(description),
"housing|homeless"
),
autism = str_detect(
str_to_lower(description),
"autism"
),
workforce = str_detect(
str_to_lower(description),
"workforce|employment|job"
)
)
# -------------------------
# Print Everything
# -------------------------
options(max.print = 100000)
print(grant_df, n = Inf)
# -------------------------
# Save CSV
# -------------------------
write.csv(
grant_df,
"grant_database.csv",
row.names = FALSE
)
cat("\nSaved: grant_database.csv\n")
# =========================
# Bullet-Based Grant Parser
# =========================
library(httr)
library(dplyr)
library(stringr)
library(tibble)
# -------------------------
# Google Doc URL
# -------------------------
doc_id <- "1DrXIoSMsCDUWayUq29VQXNfLColOqU1Q3Ojr7hfK-PQ"
url <- paste0(
"https://docs.google.com/document/d/",
doc_id,
"/export?format=txt"
)
# -------------------------
# Download Text
# -------------------------
response <- GET(url)
text_data <- content(response, "text", encoding = "UTF-8")
# -------------------------
# Normalize Text
# -------------------------
clean_text <- text_data %>%
str_replace_all("\r", "") %>%
str_replace_all("\t", " ") %>%
str_squish()
# -------------------------
# Split On Bullet Points
# -------------------------
entries <- unlist(
str_split(clean_text, "•")
)
# Remove empty rows
entries <- entries[
str_trim(entries) != ""
]
# -------------------------
# Build Data Frame
# -------------------------
grant_df <- tibble(
raw = str_trim(entries)
) %>%
mutate(
# Organization name assumed before first period
organization = str_extract(raw, "^[^.]+"),
# Description after first period
description = str_trim(
str_replace(raw, "^[^.]+\\.", "")
)
)
# -------------------------
# Add Classification Tags
# -------------------------
grant_df <- grant_df %>%
mutate(
mental_health = str_detect(
str_to_lower(description),
"mental health|behavioral health"
),
housing = str_detect(
str_to_lower(description),
"housing|homeless"
),
autism = str_detect(
str_to_lower(description),
"autism"
),
workforce = str_detect(
str_to_lower(description),
"workforce|employment|job"
)
)
# -------------------------
# Print Full Dataset
# -------------------------
options(max.print = 100000)
print(grant_df, n = Inf)
# -------------------------
# Save CSV
# -------------------------
write.csv(
grant_df,
"grant_database.csv",
row.names = FALSE
)
cat("\nSaved: grant_database.csv\n")
