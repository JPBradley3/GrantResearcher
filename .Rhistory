library(httr)
library(stringr)
library(dplyr)
library(tibble)
doc_id <- "1DrXIoSMsCDUWayUq29VQXNfLColOqU1Q3Ojr7hfK-PQ"
url <- paste0(
"https://docs.google.com/document/d/",
doc_id,
"/export?format=txt"
)
response <- GET(url)
text_data <- content(response, "text", encoding = "UTF-8")
# -------------------------
# STEP 1: normalize text
# -------------------------
txt <- text_data %>%
str_replace_all("\r", "") %>%
str_replace_all("\t", " ") %>%
str_replace_all("•", "\n") %>%     # convert bullets to newlines
str_squish()
lines <- unlist(str_split(txt, "\n"))
# -------------------------
# STEP 2: detect “organization-like” lines
# (heuristic: capitalized + longer line)
# -------------------------
is_org <- str_detect(lines, "^[A-Z0-9][A-Za-z0-9&() ,.'-]{4,}$")
# mark group IDs (each org starts a new group)
group_id <- cumsum(is_org)
df <- tibble(
line = lines,
group = group_id
) %>%
filter(line != "") %>%
group_by(group) %>%
summarise(
raw = paste(line, collapse = " "),
.groups = "drop"
) %>%
mutate(
organization = str_extract(raw, "^[^–-]+"),
description = str_replace(raw, "^[^–-]+[–-]?", "")
)
print(df, n = Inf)
library(httr)
library(stringr)
library(dplyr)
library(tibble)
doc_id <- "1DrXIoSMsCDUWayUq29VQXNfLColOqU1Q3Ojr7hfK-PQ"
url <- paste0(
"https://docs.google.com/document/d/",
doc_id,
"/export?format=txt"
)
text <- content(GET(url), "text", encoding = "UTF-8")
# -------------------------
# STEP 1: collapse everything into a single string
# -------------------------
text <- text %>%
str_replace_all("\r", "") %>%
str_replace_all("\n+", " <<<NEWLINE>>> ") %>%
str_squish()
# -------------------------
# STEP 2: define known org pattern anchors
# (capitalized multi-word phrases)
# -------------------------
org_pattern <- "([A-Z][A-Za-z&'()]+(?:\\s+[A-Z][A-Za-z&'()]+){1,6})"
matches <- str_match_all(text, org_pattern)[[1]][,1]
matches <- unique(matches)
# -------------------------
# STEP 3: extract context around each org
# -------------------------
extract_context <- function(org, text) {
pattern <- paste0(org, "(.*?)(?=([A-Z][A-Za-z&'()]+\\s|<<<NEWLINE>>>|$))")
hit <- str_match(text, pattern)
if (is.na(hit[1])) return(NA)
return(hit[1,2])
}
df <- tibble(
organization = matches
) %>%
rowwise() %>%
mutate(
context = extract_context(organization, text)
) %>%
ungroup()
print(df, n = Inf)
View(df)
# =========================
# Google Doc Grant Scraper (HTML-based, URL-safe)
# =========================
library(httr)
library(rvest)
library(stringr)
library(dplyr)
library(tibble)
# -------------------------
# Google Doc ID
# -------------------------
doc_id <- "1DrXIoSMsCDUWayUq29VQXNfLColOqU1Q3Ojr7hfK-PQ"
url <- paste0(
"https://docs.google.com/document/d/",
doc_id,
"/export?format=html"
)
# -------------------------
# Download HTML
# -------------------------
res <- GET(url)
html <- read_html(content(res, "text", encoding = "UTF-8"))
# -------------------------
# Extract text blocks
# -------------------------
paragraphs <- html %>%
html_nodes("p") %>%
html_text(trim = TRUE)
paragraphs <- paragraphs[paragraphs != ""]
# -------------------------
# Extract ALL embedded URLs
# -------------------------
urls <- html %>%
html_nodes("a") %>%
html_attr("href")
urls <- urls[!is.na(urls)]
urls <- unique(urls)
# -------------------------
# Build base dataset from paragraphs
# -------------------------
df <- tibble(raw = paragraphs) %>%
mutate(
organization = str_extract(raw, "^[A-Z0-9][A-Za-z0-9&() ,.'-]{3,}"),
description = str_replace(raw, "^[^a-zA-Z]*[A-Za-z].*?\\s", "")
)
# -------------------------
# Attach URLs (basic enrichment step)
# -------------------------
url_df <- tibble(url = urls) %>%
mutate(valid = str_detect(url, "^https?://"))
# -------------------------
# Simple keyword tagging
# -------------------------
df <- df %>%
mutate(
mental_health = str_detect(str_to_lower(raw), "mental health|behavioral health"),
housing = str_detect(str_to_lower(raw), "housing|homeless"),
workforce = str_detect(str_to_lower(raw), "workforce|employment|job"),
autism = str_detect(str_to_lower(raw), "autism")
) %>%
mutate(
score =
mental_health * 3 +
housing * 2 +
autism * 2 +
workforce * 1
) %>%
arrange(desc(score))
# -------------------------
# Output
# -------------------------
options(max.print = 100000)
print(df, n = Inf)
cat("\n--- EXTRACTED URLS ---\n")
print(url_df, n = Inf)
# -------------------------
# Save outputs
# -------------------------
write.csv(df, "grants_structured.csv", row.names = FALSE)
write.csv(url_df, "grants_urls.csv", row.names = FALSE)
cat("\nSaved: grants_structured.csv + grants_urls.csv\n")
View(url_df)
